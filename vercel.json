{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/telegram.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/set_webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/webapp.py",
      "use": "@vercel/python"
    },
    {
      "src": "webapp/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/telegram",
      "dest": "api/telegram.py"
    },
    {
      "src": "/api/set_webhook",
      "dest": "api/set_webhook.py"
    },
    {
      "src": "/api/webapp",
      "dest": "api/webapp.py"
    },
    {
      "src": "/app",
      "dest": "webapp/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/set_webhook",
      "schedule": "0 3 * * *"
    }
  ]
}
