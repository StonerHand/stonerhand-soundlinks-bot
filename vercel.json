{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/telegram.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/set_webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/webapp.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/health.py",
      "use": "@vercel/python"
    },
    {
      "src": "webapp/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "webapp/styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "webapp/app.js",
      "use": "@vercel/static"
    },
    {
      "src": "webapp/api-client.js",
      "use": "@vercel/static"
    },
    {
      "src": "webapp/cloud-storage.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/telegram",
      "dest": "api/telegram.py"
    },
    {
      "src": "/api/set_webhook",
      "dest": "api/set_webhook.py"
    },
    {
      "src": "/api/webapp",
      "dest": "api/webapp.py"
    },
    {
      "src": "/api/health",
      "dest": "api/health.py"
    },
    {
      "src": "/app",
      "dest": "webapp/index.html",
      "headers": {
        "Content-Security-Policy": "default-src 'self'; script-src 'self' https://telegram.org; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; media-src https: blob:; connect-src 'self'; frame-ancestors 'self' https://web.telegram.org https://*.telegram.org; base-uri 'none'; object-src 'none'",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
        "Referrer-Policy": "no-referrer",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "src": "/app/styles.css",
      "dest": "webapp/styles.css"
    },
    {
      "src": "/app/app.js",
      "dest": "webapp/app.js"
    },
    {
      "src": "/webapp/styles.css",
      "dest": "webapp/styles.css"
    },
    {
      "src": "/webapp/app.js",
      "dest": "webapp/app.js"
    },
    {
      "src": "/webapp/api-client.js",
      "dest": "webapp/api-client.js"
    },
    {
      "src": "/webapp/cloud-storage.js",
      "dest": "webapp/cloud-storage.js"
    }
  ],
  "crons": [
    {
      "path": "/api/set_webhook",
      "schedule": "0 3 * * *"
    }
  ]
}
